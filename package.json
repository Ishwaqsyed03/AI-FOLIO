{
  "name": "ai-portfolio-maker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup-env.mjs",
    "dev": "vite",
    "dev:server": "node scripts/local-ai-server.mjs",
    "dev:full": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$server = Start-Process -FilePath node -ArgumentList 'scripts/local-ai-server.mjs' -PassThru; try { npm run dev } finally { if ($server -and !$server.HasExited) { Stop-Process -Id $server.Id -Force } }\"",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "node scripts/setup-env.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "pdf-parse": "^2.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "vite": "^5.2.0"
  }
}
